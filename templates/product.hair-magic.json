            "custom_liquid": "<div class=\"product__block product__block--custom_liquid\">\n\n<style>\n  #derm-review-hairmagic{\n    padding: 12px !important;\n    background: #f8f8f8;\n    margin: 22px auto 12px;\n    border-radius: 10px;\n    border: 1px solid #f1f1f4;\n    box-shadow: rgba(0, 0, 0, 0.08) 0px 1px 4px;\n    max-width: 600px;\n    text-align: left;\n    overflow: hidden;\n  }\n\n  #derm-review-hairmagic .wrap{\n    display: grid;\n    grid-template-columns: 30% 70%;\n    gap: 14px;\n    align-items: start;\n  }\n\n  /* Photo */\n  #derm-review-hairmagic .photo{\n    position: relative;\n    border-radius: 10px;\n    overflow: hidden;\n    border: 1px solid #eee;\n    background: #fff;\n  }\n\n  #derm-review-hairmagic .photo img{\n    width: 100%;\n    height: 100%;\n    display: block;\n    object-fit: cover;\n    aspect-ratio: 3 / 4; /* portrait premium */\n  }\n\n  /* Content */\n  #derm-review-hairmagic .content{\n    padding-right: 4px;\n  }\n\n  #derm-review-hairmagic h6{\n    font-size: 16px;\n    font-weight: 600;\n    margin: 0 0 6px;\n    color: #111;\n  }\n\n  #derm-review-hairmagic blockquote{\n    margin: 0;\n    padding: 0;\n    font-size: 14px;\n    line-height: 1.5;\n    color: #333;\n  }\n\n  #derm-review-hairmagic .quote{\n    position: relative;\n    padding-left: 12px;\n    border-left: 2px solid #C8A265;\n  }\n\n  #derm-review-hairmagic .author{\n    margin-top: 10px;\n    display: grid;\n    gap: 2px;\n  }\n\n  #derm-review-hairmagic .name{\n    font-size: 13px;\n    font-weight: 600;\n    color: #111;\n  }\n\n  #derm-review-hairmagic .title{\n    font-size: 12px;\n    color: #666;\n  }\n\n  /* Mobile optimisation */\n  @media screen and (max-width: 767px){\n    #derm-review-hairmagic{\n      padding: 10px !important;\n      border-radius: 10px;\n    }\n\n    #derm-review-hairmagic .wrap{\n      grid-template-columns: 1fr;\n      gap: 10px;\n    }\n\n    #derm-review-hairmagic .photo img{\n      aspect-ratio: 16 / 9; /* photo plus large sur mobile */\n    }\n\n    #derm-review-hairmagic h6{\n      font-size: 15px;\n    }\n\n    #derm-review-hairmagic blockquote{\n      font-size: 13px;\n    }\n  }\n</style>\n\n<div id=\"derm-review-hairmagic\">\n  <div class=\"wrap\">\n\n    <div class=\"photo\">\n      <!-- Remplace cette image par la photo de la dermatologue -->\n      <img src=\"https://cdn.shopify.com/s/files/1/0751/4685/4590/files/zakariajawad_Professional_portrait_of_a_Moroccan_female_derma_0095bf37-ad61-4ea8-8c33-fbbdb471ef7e_0.png?v=1771336199\" alt=\"Dr. Amina K., dermatologue\">\n    </div>\n\n    <div class=\"content\">\n      <h6>Avis de dermatologue</h6>\n\n      <blockquote class=\"quote\">\n        « Les poudres enrichies en panthénol et huile d’argan sont une excellente option pour les femmes\n        qui veulent camoufler les zones clairsemées sans irriter le cuir chevelu. HairMagic+ offre un bon\n        équilibre entre couvrance et soin. »\n      </blockquote>\n\n      <div class=\"author\">\n        <div class=\"name\">— Dr. Amina K.</div>\n        <div class=\"title\">Dermatologue spécialisée en trichologie</div>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n</div>"
          }
        }
      },
