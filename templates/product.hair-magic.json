        },
        "testimonial_jEjLA4": {
          "type": "testimonial",
          "settings": {
            "stars_count": 5,
            "title": "Enfin une solution discrète",
            "text": "<p>J’ai testé des sprays et des poudres avant… toujours trop visible. Là, le résultat est propre, naturel, et ça tient toute la journée sans retouche.</p>",
            "author": "<p><strong>Sophie L.</strong> — 9 décembre 2025</p>"
          }
        },
        "testimonial_nE6UXJ": {
          "type": "testimonial",
          "settings": {
            "stars_count": 5,
            "title": "Je me sens à nouveau à l’aise",
            "text": "<p>Les racines blanches me complexaient beaucoup. HairMagic+ couvre parfaitement sans effet “maquillage”. Je sors sans y penser.</p>",
            "author": "<p><strong>Nathalie R.</strong> — 2 décembre 2025</p>"
          }
        },
        "testimonial_jRhExn": {
          "type": "testimonial",
          "settings": {
            "stars_count": 5,
            "title": "On dirait juste mes cheveux, en mieux",
            "text": "<p>Aucun effet carton, aucune sensation lourde. Même de très près, c’est indétectable. Mon coiffeur n’a rien remarqué.</p>",
