    "testimonials_HHDNMe": {
      "type": "testimonials",
      "blocks": {
        "image_Bnhnzb": {
          "type": "image",
          "settings": {
            "icon_select": "quote",
            "text": "<p><em>« Je recommande HairMagic+ à mes clientes entre deux colorations. Le résultat est bluffant et la formule ne détériore pas le cheveu. C’est rare de trouver un correcteur qui soit aussi un soin. » </em></p>",
            "desktop_image": "shopify://shop_images/zakariajawad_Laure_B._coiffeuse_visagiste_Paris_--v_7_283861ac-7157-4a80-8e9f-2f32ddcdb9e8_2.png",
